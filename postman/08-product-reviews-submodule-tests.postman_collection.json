{
  "info": {
    "name": "Simsir - 08 Product Reviews Submodule Tests",
    "_postman_id": "28a2ed91-ef33-4ffe-b8e5-8b63a01242e7",
    "description": "ProductReviews submodule regression tests including V2 admin read/list/detail endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prerequisite - Capture Active Product",
      "item": [
        {
          "name": "GET /api/products?limit=1 - capture product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "const items = Array.isArray(json.items) ? json.items : [];",
                  "pm.test('At least one active product exists', function () { pm.expect(items.length).to.be.above(0); });",
                  "if (items.length > 0) {",
                  "  pm.environment.set('productReviewsSubmoduleTestProductId', items[0].id);",
                  "  pm.environment.set('productReviewsSubmoduleTestProductSlug', items[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products?limit=1",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products?limit=1"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 Public Product Review List",
      "item": [
        {
          "name": "GET /api/products/:productId/reviews - public list should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Response has public review item shape', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  json.items.forEach(function (item) {",
                  "    pm.expect(item.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.productId).to.eql(pm.environment.get('productReviewsSubmoduleTestProductId'));",
                  "    pm.expect(item.ratingValue).to.be.a('number');",
                  "    pm.expect(item.comment).to.be.a('string');",
                  "    pm.expect(item.createdAt).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.author).to.be.an('object');",
                  "    pm.expect(item.author.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.author.name).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.author.surname).to.be.a('string').and.not.empty;",
                  "    if (Object.prototype.hasOwnProperty.call(item, 'userId')) {",
                  "      pm.expect(item.userId).to.be.a('string').and.not.empty;",
                  "    }",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products/{{productReviewsSubmoduleTestProductId}}/reviews",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products",
                "{{productReviewsSubmoduleTestProductId}}",
                "reviews"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Authenticated Review CRUD + Admin Read",
      "item": [
        {
          "name": "POST /api/products/:productId/reviews - customer create review",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('productReviewsSubmoduleTestReviewId', json.id); }",
                  "pm.test('Created review response is correct', function () {",
                  "  pm.expect(pm.environment.get('productReviewsSubmoduleTestReviewId')).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.id).to.eql(pm.environment.get('productReviewsSubmoduleTestReviewId'));",
                  "  pm.expect(json.productId).to.eql(pm.environment.get('productReviewsSubmoduleTestProductId'));",
                  "  pm.expect(json.userId).to.eql(pm.environment.get('customer_user_id'));",
                  "  pm.expect(json.ratingValue).to.eql(5);",
                  "  pm.expect(json.comment).to.eql('Postman product review V2');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customer_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products/{{productReviewsSubmoduleTestProductId}}/reviews",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products",
                "{{productReviewsSubmoduleTestProductId}}",
                "reviews"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ratingValue\": 5,\n  \"comment\": \"Postman product review V2\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "GET /api/admin/products/:productId/reviews - admin list should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Admin list includes created review', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  const reviewId = pm.environment.get('productReviewsSubmoduleTestReviewId');",
                  "  const item = json.items.find(function (entry) { return entry.id === reviewId; });",
                  "  pm.expect(item, 'Created review should appear in admin list').to.exist;",
                  "  pm.expect(item.productId).to.eql(pm.environment.get('productReviewsSubmoduleTestProductId'));",
                  "  pm.expect(item.userId).to.eql(pm.environment.get('customer_user_id'));",
                  "  pm.expect(item.ratingValue).to.eql(5);",
                  "  pm.expect(item.comment).to.eql('Postman product review V2');",
                  "});"
                ]
              }
            }
          ],
