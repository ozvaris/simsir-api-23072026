                  "  pm.expect(json.id).to.eql(pm.environment.get('productReviewsSubmoduleTestReviewId'));",
                  "  pm.expect(json.productId).to.eql(pm.environment.get('productReviewsSubmoduleTestProductId'));",
                  "  pm.expect(json.userId).to.eql(pm.environment.get('customer_user_id'));",
                  "  pm.expect(json.ratingValue).to.eql(4);",
                  "  pm.expect(json.comment).to.eql('Postman product review V2 updated');",
                  "});"
