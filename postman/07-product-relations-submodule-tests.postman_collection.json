        {
          "name": "CATALOG_MANAGER GET /api/admin/products/relations/:relationId should return 404 after delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Deleted relation is absent', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(String(json.message || '')).to.not.equal('');",
                  "});",
                  "pm.environment.unset('productRelationsSubmoduleTestSourceProductId');",
                  "pm.environment.unset('productRelationsSubmoduleTestSourceProductSlug');",
                  "pm.environment.unset('productRelationsSubmoduleTestTargetProductId');",
                  "pm.environment.unset('productRelationsSubmoduleTestRelationId');"
                ]
