{
  "info": {
    "name": "Simsir - 06 Product Media Submodule Tests",
    "_postman_id": "83df28c7-d5ba-469f-8b66-1e4e69189ddd",
    "description": "ProductMedia submodule regression tests including V2 admin list/detail endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prerequisite - Capture Active Product",
      "item": [
        {
          "name": "GET /api/products?limit=1 - capture product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "const items = Array.isArray(json.items) ? json.items : [];",
                  "pm.test('At least one active product exists', function () { pm.expect(items.length).to.be.above(0); });",
                  "if (items.length > 0) {",
                  "  pm.environment.set('productMediaSubmoduleTestProductId', items[0].id);",
                  "  pm.environment.set('productMediaSubmoduleTestProductSlug', items[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products?limit=1",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products?limit=1"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 Product Detail Still Loads Media Shape",
      "item": [
        {
          "name": "GET /api/products/:slug - product detail should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Product detail includes media array shape', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.slug).to.eql(pm.environment.get('productMediaSubmoduleTestProductSlug'));",
                  "  pm.expect(json.media).to.be.an('array');",
                  "  json.media.forEach(function (item) {",
                  "    pm.expect(item.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.productId).to.eql(pm.environment.get('productMediaSubmoduleTestProductId'));",
                  "    pm.expect(item.src).to.be.a('string').and.not.empty;",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products/{{productMediaSubmoduleTestProductSlug}}",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products",
                "{{productMediaSubmoduleTestProductSlug}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 CATALOG_MANAGER Product Media Admin CRUD + Read",
      "item": [
        {
          "name": "GET /api/admin/products/:productId/media - admin list should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Response has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  json.items.forEach(function (item) {",
                  "    pm.expect(item.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(item.productId).to.eql(pm.environment.get('productMediaSubmoduleTestProductId'));",
                  "    pm.expect(item.src).to.be.a('string').and.not.empty;",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/products/{{productMediaSubmoduleTestProductId}}/media",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "products",
                "{{productMediaSubmoduleTestProductId}}",
                "media"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /api/admin/products/:productId/media - create media",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('productMediaSubmoduleTestMediaId', json.id); }",
                  "pm.test('Created media response is correct', function () {",
                  "  pm.expect(pm.environment.get('productMediaSubmoduleTestMediaId')).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.id).to.eql(pm.environment.get('productMediaSubmoduleTestMediaId'));",
                  "  pm.expect(json.productId).to.eql(pm.environment.get('productMediaSubmoduleTestProductId'));",
                  "  pm.expect(json.src).to.eql('/assets/superstore/postman-media-v2.png');",
                  "  pm.expect(json.alt).to.eql('Postman media V2');",
                  "  pm.expect(json.sortOrder).to.eql(99);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
                }
              ]
