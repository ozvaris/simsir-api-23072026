    {
      "name": "04 Cleanup Delete Media And Unset Temp Variables",
      "item": [
        {
          "name": "DELETE /api/admin/products/media/:mediaId - delete media",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Delete response confirms success', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/products/media/{{productMediaSubmoduleTestMediaId}}",
              "host": [
                "{{Backend_URL}}"
