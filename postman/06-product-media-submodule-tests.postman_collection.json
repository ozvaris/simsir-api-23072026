              ]
            }
          },
          "response": []
        },
        {
          "name": "CATALOG_MANAGER GET /api/admin/products/media/:mediaId should return 404 after delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Deleted media is absent', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(String(json.message || '')).to.not.equal('');",
                  "});",
                  "pm.environment.unset('productMediaSubmoduleTestProductId');",
                  "pm.environment.unset('productMediaSubmoduleTestProductSlug');",
                  "pm.environment.unset('productMediaSubmoduleTestMediaId');"
                ]
              }
            }
