    {
      "name": "02 CUSTOMER Cart Happy Path",
      "item": [
        {
          "name": "GET /api/cart - customer should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "pm.test('Response has cart shape', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "  pm.expect(json).to.have.property('summary');",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('cart_id', json.id); }",
                  "if (json.items && json.items.length > 0) {",
                  "  const targetProductId = pm.environment.get('cart_test_product_id');",
                  "  const found = json.items.find(function (item) { return item.productId === targetProductId; }) || json.items[0];",
                  "  if (found && found.id) { pm.environment.set('cart_test_item_id', found.id); }",
                  "  if (found && found.quantity !== undefined) { pm.environment.set('cart_test_item_quantity', String(found.quantity)); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
