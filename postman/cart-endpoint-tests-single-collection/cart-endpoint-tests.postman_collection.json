{
  "info": {
    "name": "Simsir - Cart Endpoint Tests",
    "_postman_id": "6b788087-b44d-4c58-8bb9-bf3d25f8d624",
    "description": "Cart endpoint tests using a single Postman collection with folders. Requires Backend_URL and role token environment variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prerequisite - Capture Active Product",
      "item": [
        {
          "name": "GET /api/products - capture first active product id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "pm.test('Response has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});",
                  "pm.test('At least one public active product exists', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.items.length, 'Public products list must contain at least one product. If this fails, create an active product first.').to.be.above(0);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.items && json.items.length > 0) {",
                  "  pm.environment.set('cart_test_product_id', json.items[0].id);",
                  "  pm.environment.set('cart_test_product_slug', json.items[0].slug || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products?limit=1",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products?limit=1"
              ]
            }
          },
          "response": []
        }
      ]
    },
