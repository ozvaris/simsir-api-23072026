    {
      "name": "02 Authenticated Review CRUD + Admin Read",
      "item": [
        {
          "name": "POST /api/products/:productId/reviews - customer create review",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('ps_review_id', json.id); }",
                  "pm.test('Saved ps_review_id', function () { pm.expect(pm.environment.get('ps_review_id')).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{customer_access_token}}",
                  "type": "string"
