    {
      "name": "02 CATALOG_MANAGER Product Relation Admin Create Delete + Read",
      "item": [
        {
          "name": "GET /api/admin/products/:productId/relations - admin list should return 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "pm.test('Response has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/products/{{ps_source_product_id}}/relations",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "products",
                "{{ps_source_product_id}}",
                "relations"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /api/admin/products/:productId/relations - create relation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('ps_relation_id', json.id); }",
                  "pm.test('Saved ps_relation_id', function () { pm.expect(pm.environment.get('ps_relation_id')).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/products/{{ps_source_product_id}}/relations",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "products",
                "{{ps_source_product_id}}",
                "relations"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetProductId\": \"{{ps_target_product_id}}\",\n  \"relationType\": \"related_product\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
