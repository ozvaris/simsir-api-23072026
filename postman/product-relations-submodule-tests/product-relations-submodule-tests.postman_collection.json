{
  "info": {
    "name": "Simsir - Product Relations Submodule Tests V2",
    "_postman_id": "c614665b-4a85-473a-a045-956f47ba9171",
    "description": "ProductRelations submodule regression tests including V2 admin list/detail endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prerequisite - Capture Two Active Products",
      "item": [
        {
          "name": "GET /api/products?limit=2 - capture source and target products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "const items = Array.isArray(json.items) ? json.items : [];",
                  "pm.test('At least two active products exist', function () { pm.expect(items.length).to.be.above(1); });",
                  "if (items.length > 1) {",
                  "  pm.environment.set('ps_source_product_id', items[0].id);",
                  "  pm.environment.set('ps_target_product_id', items[1].id);",
                  "  pm.environment.set('ps_source_product_slug', items[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products?limit=2",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products?limit=2"
              ]
            }
          },
          "response": []
        }
      ]
    },
