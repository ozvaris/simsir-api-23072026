        {
          "name": "POST /api/admin/products/:productId/media - create media",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('ps_media_id', json.id); }",
                  "pm.test('Saved ps_media_id', function () { pm.expect(pm.environment.get('ps_media_id')).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
