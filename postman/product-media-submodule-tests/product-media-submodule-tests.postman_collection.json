{
  "info": {
    "name": "Simsir - Product Media Submodule Tests V2",
    "_postman_id": "83df28c7-d5ba-469f-8b66-1e4e69189ddd",
    "description": "ProductMedia submodule regression tests including V2 admin list/detail endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prerequisite - Capture Active Product",
      "item": [
        {
          "name": "GET /api/products?limit=1 - capture product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "const items = Array.isArray(json.items) ? json.items : [];",
                  "pm.test('At least one active product exists', function () { pm.expect(items.length).to.be.above(0); });",
                  "if (items.length > 0) { pm.environment.set('ps_product_id', items[0].id); pm.environment.set('ps_product_slug', items[0].slug); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products?limit=1",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products?limit=1"
              ]
            }
          },
          "response": []
        }
      ]
    },
