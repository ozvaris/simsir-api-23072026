              ]
            }
          },
          "response": []
        },
        {
          "name": "SUPER_ADMIN - GET /api/admin/system-settings/:settingId should return 404 after delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () { pm.response.to.have.status(404); });",
                  "pm.environment.unset('system_settings_test_id');",
                  "pm.environment.unset('system_settings_test_key');",
                  "pm.environment.unset('system_settings_test_suffix');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/system-settings/{{system_settings_test_id}}",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "system-settings",
                "{{system_settings_test_id}}"
              ]
            }
          },
          "response": []
        }
      ]
