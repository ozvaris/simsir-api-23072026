{
  "info": {
    "name": "Simsir - 11 System Settings Admin Tests",
    "_postman_id": "7f51d76b-87d2-4b41-9c6b-system-settings-admin-tests",
    "description": "Admin and RBAC regression tests for system settings list/detail/create/update/delete flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Prepare Runtime Variables",
      "item": [
        {
          "name": "Prepare system setting key suffix",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString();",
                  "pm.environment.set('system_settings_test_suffix', suffix);",
                  "pm.environment.set('system_settings_test_key', 'postman.system-setting.' + suffix);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/categories",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 SUPER_ADMIN CRUD",
      "item": [
        {
          "name": "SUPER_ADMIN - GET /api/admin/system-settings should return seeded settings",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "pm.test('Response is an array', function () { pm.expect(json).to.be.an('array'); });",
                  "const keys = json.map(function (item) { return item.key; });",
                  "pm.test('Seeded setting keys are visible', function () {",
                  "  pm.expect(keys).to.include('store.defaultCurrency');",
                  "  pm.expect(keys).to.include('product.defaultTax');",
                  "  pm.expect(keys).to.include('storefront.featuredProductsLimit');",
                  "  pm.expect(keys).to.include('review.autoPublishEnabled');",
                  "  pm.expect(keys).to.include('order.freeShippingThreshold');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/system-settings",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "system-settings"
              ]
            }
          },
          "response": []
        },
        {
          "name": "SUPER_ADMIN - POST /api/admin/system-settings should create custom setting",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "pm.test('Created setting has id and key', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('key');",
                  "  pm.expect(json.key).to.eql(pm.environment.get('system_settings_test_key'));",
                  "  pm.expect(json).to.have.property('value');",
                  "  pm.expect(json.value).to.eql('42');",
                  "});",
                  "pm.environment.set('system_settings_test_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"{{system_settings_test_key}}\",\n  \"value\": \"42\",\n  \"valueType\": \"number\",\n  \"groupKey\": \"postman\",\n  \"description\": \"Postman-created custom system setting.\",\n  \"isPublic\": false,\n  \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{Backend_URL}}/api/admin/system-settings",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "system-settings"
              ]
            }
          },
          "response": []
        },
        {
          "name": "SUPER_ADMIN - GET /api/admin/system-settings/:settingId should return created setting",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "pm.test('Detail returns created system setting', function () {",
                  "  pm.expect(json.id).to.eql(pm.environment.get('system_settings_test_id'));",
                  "  pm.expect(json.key).to.eql(pm.environment.get('system_settings_test_key'));",
                  "  pm.expect(json.value).to.eql('42');",
                  "  pm.expect(json.parsedValue).to.eql(42);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/admin/system-settings/{{system_settings_test_id}}",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "system-settings",
                "{{system_settings_test_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "SUPER_ADMIN - PATCH /api/admin/system-settings/:settingId should update value",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "const json = pm.response.json();",
                  "pm.test('Updated setting value is returned', function () {",
                  "  pm.expect(json.id).to.eql(pm.environment.get('system_settings_test_id'));",
                  "  pm.expect(json.value).to.eql('84');",
                  "  pm.expect(json.parsedValue).to.eql(84);",
                  "  pm.expect(json.description).to.eql('Postman-updated custom system setting.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": \"84\",\n  \"description\": \"Postman-updated custom system setting.\",\n  \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{Backend_URL}}/api/admin/system-settings/{{system_settings_test_id}}",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "admin",
                "system-settings",
                "{{system_settings_test_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "SUPER_ADMIN - DELETE /api/admin/system-settings/:settingId should delete custom setting",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });"
                ]
              }
            }
