    {
      "name": "01 Resolve Seeded Demo Product",
      "item": [
        {
          "name": "Public - GET /api/products/:slug should capture seeded product id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "pm.test('Seeded product detail includes inventory summary', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.slug).to.eql(pm.environment.get('demo_inventory_product_slug'));",
                  "  pm.expect(json.inventory).to.be.an('object');",
                  "  pm.expect(json.inventory.isTracked).to.eql(true);",
                  "  pm.expect(json.inventory.onHandQuantity).to.be.a('number');",
                  "  pm.expect(json.inventory.reservedQuantity).to.be.a('number');",
                  "  pm.expect(json.inventory.availableQuantity).to.eql(json.inventory.onHandQuantity - json.inventory.reservedQuantity);",
                  "  pm.environment.set('inventory_test_product_id', json.id);",
                  "  pm.environment.set('inventory_initial_on_hand', String(json.inventory.onHandQuantity));",
                  "  pm.environment.set('inventory_initial_reserved', String(json.inventory.reservedQuantity));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{Backend_URL}}/api/products/{{demo_inventory_product_slug}}",
              "host": [
                "{{Backend_URL}}"
              ],
              "path": [
                "api",
                "products",
                "{{demo_inventory_product_slug}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
