          "name": "SUPER_ADMIN - Login and save access token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Save super admin access token', function () {",
                  "  const json = pm.response.json();",
                  "  const accessToken = json.accessToken || json.access_token || json.data?.accessToken || json.tokens?.accessToken;",
