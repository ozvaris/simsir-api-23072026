    {
      "name": "06 Cleanup Restore Fixture",
      "item": [
        {
          "name": "CATALOG_MANAGER - restore inventory on-hand quantity to initial value",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Inventory restore response matches captured initial state', function () {",
                  "  const json = pm.response.json();",
                  "  const initialOnHand = Number(pm.environment.get('inventory_initial_on_hand'));",
                  "  const initialReserved = Number(pm.environment.get('inventory_initial_reserved'));",
                  "  pm.expect(json.inventory.isTracked).to.eql(true);",
                  "  pm.expect(json.inventory.onHandQuantity).to.eql(initialOnHand);",
                  "  pm.expect(json.inventory.reservedQuantity).to.eql(initialReserved);",
                  "  pm.expect(json.inventory.availableQuantity).to.eql(initialOnHand - initialReserved);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{catalog_manager_access_token}}",
                  "type": "string"
