        {
          "name": "ORDER_MANAGER - POST /api/admin/shipping-carriers should return 200 or 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is one of [200, 201]', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('Save shipping carrier id to environment', function () {",
                  "  const json = pm.response.json();",
                  "  const entity = json.data || json.item || json;",
                  "  const id = entity.id || entity.shippingCarrierId || entity.paymentMethodId;",
                  "  pm.expect(id, 'created entity id').to.be.a('string').and.not.empty;",
                  "  pm.environment.set('order_manager_shipping_carrier_id', id);",
                  "});"
                ]
              }
            }
          ],
