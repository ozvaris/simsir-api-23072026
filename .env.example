APP_PORT=4000
NODE_ENV=development

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=bazar_user
DB_PASSWORD=bazar_password
DB_DATABASE=bazar_db

JWT_SECRET=dev_super_secret_change_me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Seed execution flags
# In development, system/reference seed runs by default unless explicitly disabled.
SEED_SYSTEM_DATA=true
SEED_REFERENCE_DATA=true
SEED_DEMO_DATA=true
SEED_DEFAULT_USER_PASSWORD=pass1234

# Production seed safety gate
ENABLE_PRODUCTION_SEED=false

# Manual super admin bootstrap defaults
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPER_ADMIN_USERNAME=super.admin
BOOTSTRAP_SUPER_ADMIN_NAME=Super
BOOTSTRAP_SUPER_ADMIN_SURNAME=Admin
BOOTSTRAP_SUPER_ADMIN_PHONE=
BOOTSTRAP_SUPER_ADMIN_PASSWORD=pass1234
